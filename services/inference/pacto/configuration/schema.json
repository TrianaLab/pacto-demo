{
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "description": "Host address to bind the server",
      "default": "0.0.0.0"
    },
    "log_level": {
      "type": "string",
      "description": "Log level (debug, info, warn, error)",
      "default": "info",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "max_retries": {
      "type": "integer",
      "description": "Maximum number of retries for runtime calls",
      "default": "3"
    },
    "port": {
      "type": "integer",
      "description": "Port to listen on",
      "default": "8082"
    },
    "runtime_url": {
      "type": "string",
      "description": "URL of the runtime service"
    },
    "timeout_seconds": {
      "type": "integer",
      "description": "Request timeout in seconds",
      "default": "30"
    }
  },
  "required": [
    "runtime_url"
  ]
}