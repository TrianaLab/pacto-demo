{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Notification Worker Config",
  "type": "object",
  "properties": {
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info"
    },
    "LOG_FORMAT": {
      "type": "string",
      "enum": ["json", "text"],
      "default": "json"
    },
    "OTEL_EXPORTER_ENDPOINT": {
      "type": "string",
      "format": "uri"
    },
    "WORKER_CONCURRENCY": {
      "type": "integer",
      "default": 5
    },
    "RETRY_MAX_ATTEMPTS": {
      "type": "integer",
      "default": 3
    },
    "RETRY_BACKOFF_SECONDS": {
      "type": "integer",
      "default": 5
    },
    "DEAD_LETTER_QUEUE_ENABLED": {
      "type": "boolean",
      "default": true
    },
    "OTEL_SERVICE_NAME": {
      "type": "string"
    },
    "EMAIL_PROVIDER_URL": {
      "type": "string",
      "format": "uri"
    },
    "EMAIL_FROM": {
      "type": "string",
      "format": "email"
    },
    "SENDGRID_API_KEY": {
      "type": "string"
    }
  },
  "required": ["LOG_LEVEL", "WORKER_CONCURRENCY", "RETRY_MAX_ATTEMPTS", "EMAIL_PROVIDER_URL", "EMAIL_FROM", "SENDGRID_API_KEY"]
}
